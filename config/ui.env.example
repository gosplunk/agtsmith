# Example A.G.E.N.T. Smith runtime configuration.
# Copy to config/ui.env and replace values for the target environment.

OLLAMA_MODEL_QUERY_PLANNER=hf.co/MaziyarPanahi/Qwen3-30B-A3B-Instruct-2507-GGUF:Q4_K_M
OLLAMA_MODEL_QUERY_WRITER=deepseek-coder-v2:lite
OLLAMA_MODEL_QUERY_REPAIR=deepseek-coder-v2:lite
OLLAMA_MODEL_EVIDENCE_REVIEWER=hf.co/fdtn-ai/Foundation-Sec-8B-Reasoning-Q8_0-GGUF:latest
OLLAMA_MODEL_SECURITY_REVIEWER=hf.co/fdtn-ai/Foundation-Sec-8B-Reasoning-Q8_0-GGUF:latest
OLLAMA_MODEL_PEER_REVIEWER=hf.co/MaziyarPanahi/Qwen3-30B-A3B-Instruct-2507-GGUF:Q4_K_M
OLLAMA_MODEL_PEER_REVIEWER_2=hf.co/MaziyarPanahi/Qwen3-30B-A3B-Instruct-2507-GGUF:Q4_K_M
OLLAMA_MODEL_AGENTIC_CONTINUATION_REVIEWER=hf.co/fdtn-ai/Foundation-Sec-8B-Reasoning-Q8_0-GGUF:latest
OLLAMA_MODEL_FINAL_SUMMARY=hf.co/fdtn-ai/Foundation-Sec-8B-Reasoning-Q8_0-GGUF:latest
OLLAMA_MODEL_AGENTIC_SUMMARY=hf.co/fdtn-ai/Foundation-Sec-8B-Reasoning-Q8_0-GGUF:latest

OLLAMA_AGENTIC_CONTINUATION_TIMEOUT_SEC=180
OLLAMA_AGENTIC_AUTO_CONTINUE_LIMIT=1
OLLAMA_AGENTIC_MAX_INVESTIGATION_DEPTH=3
OLLAMA_AGENTIC_CONTINUE_CONFIDENCE_THRESHOLD=0.6

SOC_UI_AUTH_ENABLED=1
# First-run setup can create the initial user in the web UI.
# Optional preseeded local user store example:
# SOC_UI_AUTH_USERS_JSON=[{"username":"smithadmin","password":"Replace-With-A-Strong-Password","role":"admin"}]
SOC_UI_AUTH_USERNAME=opsadmin
SOC_UI_AUTH_PASSWORD=Replace-With-A-Strong-Password
SOC_UI_AUTH_ROLE=admin
SOC_UI_AUTH_INITIALIZED=0

OLLAMA_HOST=http://127.0.0.1:11434
EDGE_LLM_ENABLED=0
EDGE_LLM_HOST=
EDGE_LLM_MODEL=
EDGE_LLM_ROLE=edge_router_splitter
EDGE_LLM_TIMEOUT_SEC=60
SPLUNK_BASE_URL=https://127.0.0.1:8089
# Optional explicit Splunk Web URL override for Open In Splunk links.
# Set this when Splunk Web is not reachable on the default inferred URL from the A.G.E.N.T. Smith host.
# SPLUNK_WEB_URL=https://127.0.0.1:8000
SPLUNK_MCP_URL=https://127.0.0.1:8089/services/mcp
SPLUNK_LAB_BEARER_TOKEN=replace-with-your-splunk-mcp-token

# Optional external case store override.
# The deployment compose stack now starts PostgreSQL automatically for case timelines.
# Override these only if you want the web UI to point at a different PostgreSQL instance.
# AGTSMITH_CASE_DB_DSN=host=127.0.0.1 port=5432 dbname=agtsmith user=agtsmith password=replace-me
# AGTSMITH_CASE_DB_HOST=127.0.0.1
# AGTSMITH_CASE_DB_PORT=5432
# AGTSMITH_CASE_DB_NAME=agtsmith
# AGTSMITH_CASE_DB_USER=agtsmith
# AGTSMITH_CASE_DB_PASSWORD=replace-me

# Optional HTTPS for the built-in web server when you provide cert and key files
# AGTSMITH_TLS_CERT_FILE=/app/certs/fullchain.pem
# AGTSMITH_TLS_KEY_FILE=/app/certs/privkey.pem
